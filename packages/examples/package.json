{
  "name": "@kalisio/krawler-examples",
  "description": "A collection of krawler job examples (adsb, airports, bdtopo, csv2db, dem2csv, docker, extend, wms2yaml, aeroway)",
  "version": "0.0.0",
  "type": "module",
  "standard": {
    "ignore": [
      "docker/src/**"
    ]
  },
  "scripts": {
    "lint": "standard --fix",
    "example:adsb": "krawler adsb/jobfile.js",
    "example:aeroway": "krawler aeroway/jobfile.js",
    "example:airports": "krawler airports/jobfile.js",
    "example:bdtopo": "krawler bdtopo/jobfile.js",
    "example:csv2db:mongo": "krawler csv2db/jobfile.mongo.js",
    "example:csv2db:pg": "krawler csv2db/jobfile.pg.js",
    "example:dem2csv": "krawler dem2csv/jobfile.js",
    "example:docker:convert": "krawler docker/jobfile-convert.js",
    "example:docker:print": "krawler docker/jobfile-print.js",
    "example:extend": "krawler extend/index.js",
    "example:wms2yaml": "krawler wms2yaml/jobfile.js"
  },
  "keywords": [
    "krawler",
    "etl",
    "examples",
    "kalisio"
  ],
  "author": {
    "name": "KALISIO <contact@kalisio.com>",
    "url": "https://github.com/kalisio"
  },
  "contributors": [],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git://github.com/kalisio/krawler-ekosystem.git",
    "directory": "packages/examples"
  },
  "bugs": {
    "url": "https://github.com/kalisio/krawler-ekosystem/issues"
  },
  "homepage": "https://github.com/kalisio/krawler-ekosystem/tree/main/packages/examples",
  "dependencies": {
    "@kalisio/krawler": "workspace:*"
  },
  "devDependencies": {
    "standard": "catalog:"
  }
}
