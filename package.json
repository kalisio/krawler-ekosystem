{
  "name": "krawler-ekosystem",
  "description": "Kalisio Krawler and all related jobs for data collection",
  "type": "module",
  "packageManager": "pnpm@10.1.0",
  "scripts": {
    "build": "pnpm -r build",
    "build:krawler": "pnpm --filter @kalisio/krawler build",
    "build:krawler-openradiation": "pnpm --filter @kalisio/krawler-openradiation build",
    "build:krawler-vigicrues": "pnpm --filter @kalisio/krawler-vigicrues build",
    "changeset": "changeset",
    "changeset:publish": "pnpm build && changeset publish",
    "changeset:status": "changeset status",
    "changeset:version": "changeset version",
    "clear": "pnpm -r exec rimraf node_modules dist coverage",
    "docs:build": "vitepress build docs",
    "docs:dev": "vitepress dev docs",
    "inspect": "pnpm knip",
    "lint": "pnpm -r lint",
    "lint:krawler": "pnpm --filter @kalisio/krawler lint",
    "lint:krawler-openradiation": "pnpm --filter @kalisio/krawler-openradiation lint",
    "lint:krawler-vigicrues": "pnpm --filter @kalisio/krawler-vigicrues lint",
    "lint:unused": "pnpm knip",
    "posttest": "pnpm lcov-result-merger --prepend-source-files 'packages/*/coverage/lcov.info' coverage/lcov.info",
    "prepare": "husky",
    "pretest": "mkdir -p coverage",
    "test": "pnpm -r test",
    "test:krawler": "pnpm --filter @kalisio/krawler test",
    "test:krawler-openradiation": "pnpm --filter @kalisio/krawler-openradiation test",
    "test:krawler-vigicrues": "pnpm --filter @kalisio/krawler-vigicrues test"
  },
  "keywords": [
    "kalisio"
  ],
  "author": {
    "name": "KALISIO <contact@kalisio.com>",
    "url": "https://github.com/kalisio"
  },
  "contributors": [],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git://github.com/kalisio/krawler-ekosystem.git"
  },
  "bugs": {
    "url": "https://github.com/kalisio/krawler-ekosystem/issues"
  },
  "homepage": "git://github.com/kalisio/krawler-ekosystem#readme",
  "dependencies": {
    "keycloak-js": "catalog:",
    "lodash": "catalog:",
    "moment": "catalog:",
    "quasar": "catalog:"
  },
  "devDependencies": {
    "@changesets/cli": "catalog:",
    "@vitest/coverage-v8": "catalog:",
    "cross-env": "catalog:",
    "husky": "catalog:",
    "knip": "catalog:",
    "lcov-result-merger": "catalog:",
    "lint-staged": "catalog:",
    "mermaid": "catalog:",
    "rimraf": "catalog:",
    "standard": "catalog:",
    "vite": "catalog:",
    "vite-bundle-visualizer": "catalog:",
    "vitepress": "catalog:",
    "vitepress-plugin-mermaid": "catalog:",
    "vitepress-theme-kalisio": "catalog:",
    "vitest": "catalog:"
  },
  "metaCatalog": {
    "version": "0.9.0",
    "syncedAt": "2026-04-30T07:30:33.947Z"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "gdal-async"
    ]
  }
}